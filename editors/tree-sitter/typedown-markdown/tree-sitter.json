{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "typedown_markdown",
      "camelcase": "TypedownMarkdown",
      "title": "Typedown Markdown",
      "scope": "source.tdr.markdown",
      "injection-regex": "^typedown_markdown$",
      "class-name": "TreeSitterTypedownMarkdown"
    }
  ],
  "metadata": {
    "version": "0.0.0",
    "license": "AGPL",
    "description": "Tree-sitter grammar for typedown Markdown body",
    "authors": [
      {
        "name": "Huy-DNA",
        "email": "huydo862003@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/Huy-DNA/typedown"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
