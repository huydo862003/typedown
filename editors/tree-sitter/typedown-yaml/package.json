{
  "name": "tree-sitter-typedown-yaml",
  "version": "0.0.0",
  "description": "Tree-sitter grammar for typedown YAML frontmatter",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Huy-DNA/typedown.git",
    "directory": "editors/tree-sitter/typedown-yaml"
  },
  "license": "AGPL",
  "author": {
    "name": "Huy-DNA",
    "email": "huydo862003@gmail.com"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
