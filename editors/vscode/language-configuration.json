{
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["*", "*"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*([-*]\\s|>\\s|\\w+:\\s*$)",
    "decreaseIndentPattern": "^\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*>-\\s.+$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*>\\s*-\\s\\[.\\]\\s.+$",
      "action": { "indent": "none", "appendText": "> - [ ] " }
    },
    {
      "beforeText": "^\\s*>\\s*-\\s\\[.\\]\\s*$",
      "action": { "indent": "none", "removeText": 8 }
    },
    {
      "beforeText": "^\\s*>\\s*-\\s.+$",
      "action": { "indent": "none", "appendText": "> - " }
    },
    {
      "beforeText": "^\\s*>\\s*-\\s*$",
      "action": { "indent": "none", "removeText": 4 }
    },
    {
      "beforeText": "^\\s*>\\s+\\S.*$",
      "action": { "indent": "none", "appendText": "> " }
    },
    {
      "beforeText": "^\\s*>\\s*$",
      "action": { "indent": "outdent", "removeText": 2 }
    },
    {
      "beforeText": "^\\s*-\\s\\[.\\]\\s.+$",
      "action": { "indent": "none", "appendText": "- [ ] " }
    },
    {
      "beforeText": "^\\s*-\\s\\[.\\]\\s*$",
      "action": { "indent": "outdent", "removeText": 6 }
    },
    {
      "beforeText": "^\\s*-\\s.+$",
      "action": { "indent": "none", "appendText": "- " }
    },
    {
      "beforeText": "^\\s*-\\s*$",
      "action": { "indent": "outdent", "removeText": 2 }
    },
    {
      "beforeText": "^\\s*\\*\\s.+$",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^\\s*\\*\\s*$",
      "action": { "indent": "outdent", "removeText": 2 }
    },
    {
      "beforeText": "^\\s*\\d+\\.\\s.+$",
      "action": { "indent": "none", "appendText": "1. " }
    },
    {
      "beforeText": "^\\s*\\d+\\.\\s*$",
      "action": { "indent": "outdent", "removeText": 3 }
    }
  ]
}
