  "scripts": {
    "build:grammar": "json5 -o syntaxes/tdr.tmLanguage.json syntaxes/tdr.tmLanguage.json5",
    "build:rust": "cargo build -p typedown-lsp && TYPEDOWN_BINARY_SOURCE=local node scripts/setup-binary.mjs",
    "check-types": "tsc --noEmit",
    "fetch:staging": "TYPEDOWN_BINARY_SOURCE=staging node scripts/setup-binary.mjs",

    "lint": "eslint src",
    "lint:fix": "eslint src --fix",

    "compile": "pnpm run build:grammar && pnpm run check-types && pnpm run lint && node esbuild.js",
    "compile:dev": "pnpm run build:rust && pnpm run compile",
    "compile:staging": "pnpm run fetch:staging && pnpm run compile",
    "compile-tests": "tsc -p . --outDir out",

    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:rust": "cargo watch --workdir ../.. -w crates -s \"cargo build -p typedown-lsp && TYPEDOWN_BINARY_SOURCE=local node editors/vscode/scripts/setup-binary.mjs\"",
    "watch:dev": "npm-run-all -p watch:rust watch:esbuild watch:tsc",
    "watch:staging": "npm-run-all -p watch:esbuild watch:tsc",
    "watch-tests": "tsc -p . -w --outDir out",

    "test": "vscode-test",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",

    "package": "pnpm run build:grammar && pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "vscode:prepublish": "pnpm run package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~24.13.3",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "json5": "^2.2.3",
    "npm-run-all": "^4.1.5",
    "shx": "^0.4.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  }
}
