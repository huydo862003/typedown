        "icon": {
          "light": "./icons/tdr.svg",
          "dark": "./icons/tdr.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "typedown",
        "scopeName": "source.tdr",
        "path": "./syntaxes/tdr.tmLanguage.json"
      },
      {
        "scopeName": "tdr.javascript.codeblock",
        "path": "./syntaxes/javascript-codeblock.json",
        "injectTo": [
          "source.tdr"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript"
        }
      },
      {
        "scopeName": "tdr.typescript.codeblock",
        "path": "./syntaxes/typescript-codeblock.json",
