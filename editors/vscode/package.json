{
  "$schema": "https://json.schemastore.org/package",
  "license": "AGPL-3.0-only",
  "publisher": "hdnax",
  "name": "typedown-vscode",
  "displayName": "Typedown",
  "description": "vscode extension providing lsp services for the typedown language",
  "private": true,
  "author": "Huy-DNA <huydo862003@gmail.com>",
  "version": "0.0.0",
  "engines": {
    "vscode": "^1.121.0"
  },
  "categories": [
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:typedown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "typedown",
        "aliases": [
          "Typedown",
          "tdr"
        ],
        "extensions": [
          ".tdr"
