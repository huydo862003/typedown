{
  "scopeName": "tdr.elixir.codeblock",
  "injectionSelector": "L:source.tdr",
  "patterns": [
    {
      "begin": "(^```+)(elixir|ex)\\s*$",
      "end": "^(\\1)\\s*$",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.code.begin.tdr"
        },
        "2": {
          "name": "entity.name.tag.tdr"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.code.end.tdr"
        }
      },
      "contentName": "meta.embedded.block.elixir",
      "patterns": [
        {
          "include": "source.elixir"
        }
      ]
    }
  ]
}
