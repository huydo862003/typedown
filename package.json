{
  "$schema": "https://json.schemastore.org/package",
  "name": "typedown",
  "author": "Huy-DNA <huydo862003@gmail.com>",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "cargo build && pnpm -r run build",
