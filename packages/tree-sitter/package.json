  "scripts": {
    "generate": "bash scripts/generate.sh",
    "build:so": "pnpm run generate && bash scripts/build.sh so",
    "build:wasm": "pnpm run generate && bash scripts/build.sh wasm",
    "build": "pnpm run generate && bash scripts/build.sh all",
    "test": "bash scripts/test.sh",
    "prestart": "pnpm run build:wasm",
    "start": "tree-sitter playground"
  }
}
