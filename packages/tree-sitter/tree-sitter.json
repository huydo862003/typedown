{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "typedown",
      "camelcase": "Typedown",
      "title": "Typedown",
      "scope": "source.tdr",
      "file-types": ["tdr"],
      "path": ".",
      "injection-regex": "^typedown$",
      "class-name": "TreeSitterTypedown"
    },
    {
      "name": "typedown_yaml",
      "camelcase": "TypedownYaml",
      "title": "Typedown YAML",
      "scope": "source.tdr.yaml",
      "path": "typedown-yaml",
      "file-types": [],
      "injection-regex": "^typedown_yaml$",
      "class-name": "TreeSitterTypedownYaml"
    },
    {
      "name": "typedown_md",
      "camelcase": "TypedownMd",
      "title": "Typedown Markdown",
      "scope": "source.tdr.md",
      "path": "typedown-md",
      "file-types": [],
      "injection-regex": "^typedown_md$",
      "class-name": "TreeSitterTypedownMd"
    },
    {
      "name": "typedown_md_inline",
      "camelcase": "TypedownMdInline",
      "title": "Typedown Markdown Inline",
      "scope": "source.tdr.md.inline",
      "path": "typedown-md-inline",
      "file-types": [],
      "injection-regex": "^typedown_md_inline$",
      "class-name": "TreeSitterTypedownMdInline"
    }
  ],
  "metadata": {
    "version": "0.0.0",
    "license": "AGPL",
    "description": "Typedown grammar for tree-sitter",
    "authors": [
      {
        "name": "Huy-DNA",
        "email": "huydo862003@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/huydo862003/typedown/packages/tree-sitter",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
