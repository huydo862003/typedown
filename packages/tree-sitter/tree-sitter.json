{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tdr",
      "camelcase": "Tdr",
      "title": "Typedown TDR",
      "scope": "source.tdr",
      "file-types": ["tdr"],
      "path": ".",
      "injection-regex": "^tdr$",
      "class-name": "TreeSitterTdr"
    },
    {
      "name": "tdr_yaml",
      "camelcase": "TdrYaml",
      "title": "Typedown TDR YAML",
      "scope": "source.tdr.yaml",
      "path": "tdr-yaml",
      "file-types": [],
      "injection-regex": "^tdr_yaml$",
      "class-name": "TreeSitterTdrYaml"
    },
    {
      "name": "tdr_md",
      "camelcase": "TdrMd",
      "title": "Typedown TDR Markdown",
      "scope": "source.tdr.md",
      "path": "tdr-md",
      "file-types": [],
      "injection-regex": "^tdr_md$",
      "class-name": "TreeSitterTdrMd"
    },
    {
      "name": "tdr_md_inline",
      "camelcase": "TdrMdInline",
      "title": "Typedown TDR Markdown Inline",
      "scope": "source.tdr.md.inline",
      "path": "tdr-md-inline",
      "file-types": [],
      "injection-regex": "^tdr_md_inline$",
      "class-name": "TreeSitterTdrMdInline"
    }
  ],
  "metadata": {
    "version": "0.0.0",
    "license": "AGPL",
    "description": "Typedown TDR grammar for tree-sitter",
    "authors": [
      {
        "name": "Huy-DNA",
        "email": "huydo862003@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/huydo862003/typedown/packages/tree-sitter",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
